<!-- Lightbox Modal (Universal Flex-Frame) -->
<div id="lightbox-modal" class="lightbox-modal" aria-hidden="true">
	<div class="lightbox-overlay" id="lightbox-overlay">
		<button class="lightbox-close" id="lightbox-close" aria-label="Close">&times;</button>
		<div class="lightbox-frame" id="lightbox-frame">
			<div class="lightbox-content" id="lightbox-content" role="dialog" aria-modal="true"></div>
		</div>
	</div>
</div>

<style>
	:global(main),
	:global(section) {
		padding-top: 3.1rem !important;
		padding-bottom: 3.1rem !important;
	}

	:global(#about) {
		padding-top: 2.2rem !important;
		padding-bottom: 2.2rem !important;
	}

	:global(#projects .section-heading),
	:global(#education .section-heading),
	:global(#recommendations .section-heading),
	:global(#skills .section-heading) {
		margin-top: 0.35rem !important;
	}

	@media (max-width: 640px) {
		:global(main),
		:global(section) {
			padding-top: 1.9rem !important;
			padding-bottom: 1.9rem !important;
		}

		:global(#about) {
			padding-top: 1.4rem !important;
			padding-bottom: 1.35rem !important;
		}

		:global(#projects .section-heading),
		:global(#education .section-heading),
		:global(#recommendations .section-heading),
		:global(#skills .section-heading) {
			margin-top: 0.25rem !important;
		}
	}

	/* ── Lightbox ── */
	.lightbox-modal {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 1999;
	}

	.lightbox-modal.active {
		display: flex;
	}

	.lightbox-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.85);
		display: flex;
		align-items: center;
		justify-content: center;
		/* Leave permanent room at the bottom for browser UI */
		padding-bottom: 80px;
		animation: lb-fade 200ms ease;
	}

	@keyframes lb-fade {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	.lightbox-frame {
		display: flex !important;
		align-items: center !important;
		justify-content: center !important;
		height: 100dvh !important;
		width: 100vw !important;
	}

	.lightbox-content {
		display: flex !important;
		align-items: center !important;
		justify-content: center !important;
		height: 100% !important;
		width: 100% !important;
	}

	.lightbox-content img,
	.lightbox-content video {
		max-height: 85dvh !important;
		max-width: 90vw !important;
		width: auto;
		height: auto;
		object-fit: contain;
		display: block;
		margin: auto !important;
		border-radius: 10px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
		background: #000;
		opacity: 0;
		transform: scale(0.95);
		transition: opacity 260ms ease, transform 260ms ease;
	}

	.lightbox-modal.active .lightbox-content img,
	.lightbox-modal.active .lightbox-content video {
		opacity: 1;
		transform: scale(1);
	}

	/* Close button – fixed top-right of viewport */
	.lightbox-close {
		position: fixed;
		top: 20px;
		right: 20px;
		width: 48px;
		height: 48px;
		border-radius: 50%;
		border: none;
		cursor: pointer;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(10px);
		color: #fff;
		font-size: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 2000;
		transition: background 180ms ease, color 180ms ease, transform 120ms ease;
	}

	.lightbox-close:hover {
		background: #fff;
		color: #000;
		transform: translateY(-2px);
	}

	@media (max-width: 420px) {
		.lightbox-close { top: 12px; right: 12px; width: 42px; height: 42px; }
	}
</style>

<script>
	declare global {
		interface Window {
			__lightbox: { open: (mediaEl: HTMLElement, triggerEl: HTMLElement) => void; close: () => void };
		}
	}

	(function () {
		const modal   = document.getElementById('lightbox-modal')   as HTMLElement | null;
		const overlay = document.getElementById('lightbox-overlay') as HTMLElement | null;
		const closeBtn = document.getElementById('lightbox-close')  as HTMLElement | null;
		const content = document.getElementById('lightbox-content') as HTMLElement | null;

		if (!modal || !overlay || !closeBtn || !content) return;

		function openModalWithMedia(mediaEl: HTMLElement, triggerEl: HTMLElement): void {
			// Pause background video in the project card (if any) to prevent double playback
			try {
				const card = triggerEl.closest<HTMLElement>('.project-card');
				const bgVideo = card?.querySelector<HTMLVideoElement>('video');
				bgVideo?.pause();
				// Also pause the clicked element if it's a video
				if (mediaEl instanceof HTMLVideoElement) mediaEl.pause();
			} catch (e) {}

			// Clear previous
			content!.innerHTML = '';

			const tag = mediaEl.tagName.toLowerCase();
			let node: HTMLImageElement | HTMLVideoElement;

			if (tag === 'img') {
				const img = mediaEl as HTMLImageElement;
				node = document.createElement('img');
				node.src = img.src || img.getAttribute('data-src') || '';
				node.alt = img.alt || '';
				node.style.maxHeight = '85dvh';
				node.style.maxWidth = '90vw';
				node.style.width = 'auto';
				node.style.height = 'auto';
				node.style.objectFit = 'contain';
			} else if (tag === 'video') {
				const vid = mediaEl as HTMLVideoElement;
				node = document.createElement('video');
				const src = vid.currentSrc
					|| vid.querySelector('source')?.src
					|| vid.src
					|| vid.getAttribute('data-src')
					|| '';
				if (src) node.src = src;
				node.setAttribute('controls', '');
				node.controls = true;
				node.playsInline = true;
				node.autoplay = false;
				// Mirror CSS constraint so the browser lays out the video
				// correctly before the stylesheet kicks in
				node.style.maxHeight = '85dvh';
				node.style.maxWidth = '90vw';
				node.style.width = 'auto';
				node.style.height = 'auto';
				node.style.objectFit = 'contain';
			} else {
				const nested = mediaEl.querySelector<HTMLElement>('img,video');
				if (nested) return openModalWithMedia(nested, triggerEl);
				return;
			}

			node.className = 'lightbox-media';
			node.addEventListener('click', (e) => e.stopPropagation());

			content!.appendChild(node);

			// Show modal and lock scroll
			modal!.classList.add('active');
			modal!.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';

			// Trigger CSS transition
			window.requestAnimationFrame(() => {
				(node as HTMLElement).style.opacity = '';
				(node as HTMLElement).style.transform = '';
			});
		}

		function closeModal(): void {
			if (!modal!.classList.contains('active')) return;

			document.body.style.overflow = '';
			modal!.setAttribute('aria-hidden', 'true');

			// Fully stop modal video to prevent ghost audio
			const media = content!.querySelector<HTMLVideoElement>('video');
			if (media) {
				try { media.pause(); }       catch (e) {}
				try { media.currentTime = 0; } catch (e) {}
				try { media.src = ''; }      catch (e) {}
				try { media.load(); }        catch (e) {}
				try { media.parentNode?.removeChild(media); } catch (e) {}
			}

			modal!.classList.remove('active');
			setTimeout(() => { content!.innerHTML = ''; }, 220);
		}

		// Delegate opening clicks
		document.addEventListener('click', (ev) => {
			const target = ev.target as Element | null;
			const trigger = target?.closest<HTMLElement>('.lightbox-trigger');
			if (!trigger) return;

			// Determine the actual media element
			let mediaEl: HTMLElement = trigger;
			if (trigger.tagName.toLowerCase() !== 'img' && trigger.tagName.toLowerCase() !== 'video') {
				const nested = trigger.querySelector<HTMLElement>('img,video');
				if (nested) mediaEl = nested;
			}

			if (!mediaEl) return;

			// Avoid firing when clicking native video controls
			if (ev.target !== trigger && ev.target !== mediaEl) {
				if (mediaEl instanceof HTMLVideoElement) {
					const rect = mediaEl.getBoundingClientRect();
					const controlBarHeight = Math.min(80, Math.max(40, Math.round(rect.height * 0.12)));
					if (ev.clientY - rect.top > rect.height - controlBarHeight) return;
				} else {
					return;
				}
			}

			ev.preventDefault();

			// Pause background/project-card video before opening
			try {
				const card = trigger.closest<HTMLElement>('.project-card');
				card?.querySelector<HTMLVideoElement>('video')?.pause();
			} catch (e) {}

			openModalWithMedia(mediaEl, trigger);
		});

		// Close interactions
		closeBtn.addEventListener('click', closeModal);

		overlay.addEventListener('click', (e) => {
			const target = e.target as Element;
			// Close if clicking directly on overlay or the frame
			if (target === overlay || target.id === 'lightbox-frame' || target.id === 'lightbox-content') {
				closeModal();
			}
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') closeModal();
		});

		// Expose for debugging
		window.__lightbox = { open: openModalWithMedia, close: closeModal };
	})();
</script>

