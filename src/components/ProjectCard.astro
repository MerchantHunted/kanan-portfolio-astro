---
interface Props {
	title: string;
	description: string;
	image?: string;
	images?: string[];
	video?: string;
	technologies: string[];
	github?: string;
	demo?: string;
	buttonLabel?: string;
}

const { title, description, image, images, video, technologies, github, demo, buttonLabel } = Astro.props;
---

<div class="project-card">
	<div class="project-header">
		<h3>{title}</h3>
	</div>

	{video && (
		<div class="media-container">
			<video src={video} autoplay loop muted playsinline style="width:100%; height:auto; max-height:250px; object-fit:contain; border-radius:8px;"></video>
		</div>
	)}
	{images && images.length > 0 && (
		<div class="media-container">
			<div style="display: flex; gap: 10px; flex-wrap: wrap;">
				{images.map((img) => (
					<img src={img} alt={title} style="flex: 1; min-width: 45%; height: auto; border-radius: 8px; object-fit: cover;" />
				))}
			</div>
		</div>
	)}
	{image && !video && !images && (
		<div class="media-container">
			<img src={image} alt={title} style="width:100%; height:auto; border-radius:8px;" />
		</div>
	)}

	<div class="project-content">
		<p>{description}</p>

		<div class="tech-stack">
			{technologies.map((tech) => (
				<span class="tech-badge">{tech}</span>
			))}
		</div>

		<div class="project-links">
			{github && (
				<a href={github} class="link-button" target="_blank" rel="noopener noreferrer">
					{buttonLabel || "Source"}
				</a>
			)}
			{demo && (
				<a href={demo} class="link-button" target="_blank" rel="noopener noreferrer">
					Demo
				</a>
			)}
		</div>
	</div>
</div>

<style>
	.project-card {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 16px;
		overflow: hidden;
		transition: all 0.25s cubic-bezier(0.23, 1, 0.320, 1);
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.project-card:hover {
		transform: translateY(-6px);
		border-color: var(--border-hover);
		box-shadow: 0 12px 40px rgba(0, 217, 255, 0.1);
	}

	.project-header {
		padding: 2rem;
		border-bottom: 1px solid var(--border);
	}

	.project-header h3 {
		margin: 0;
		color: var(--text);
		font-size: 1.4rem;
		font-weight: 700;
	}

	.media-container {
		width: 100%;
		background: rgba(0, 0, 0, 0.3);
		border-radius: 0;
		overflow: hidden;
		aspect-ratio: 16 / 9;
	}

	.media-container video,
	.media-container img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.project-content {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		flex: 1;
	}

	.project-content p {
		margin: 0;
		color: var(--text-muted);
		line-height: 1.7;
		font-size: 0.95rem;
	}

	.tech-stack {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.tech-badge {
		background: rgba(0, 217, 255, 0.08);
		color: var(--accent);
		padding: 0.5rem 0.875rem;
		border-radius: 8px;
		font-size: 0.8rem;
		font-family: 'Fira Code', 'Monaco', monospace;
		border: 1px solid rgba(0, 217, 255, 0.15);
		transition: all 0.2s ease;
	}

	.tech-badge:hover {
		background: rgba(0, 217, 255, 0.15);
		border-color: rgba(0, 217, 255, 0.3);
	}

	.project-links {
		display: flex;
		gap: 1rem;
		margin-top: auto;
	}

	.link-button {
		padding: 0.65rem 1.25rem;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text);
		border-radius: 10px;
		border: 1.5px solid var(--border);
		background: rgba(0, 217, 255, 0.08);
		transition: all 0.2s ease;
	}

	.link-button:hover {
		background: rgba(0, 217, 255, 0.18);
		border-color: var(--accent);
		color: var(--accent);
		transform: translateY(-2px);
	}
</style>
