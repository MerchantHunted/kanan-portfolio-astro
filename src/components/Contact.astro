---
interface Contact {
	label: string;
	value: string;
	href: string;
	icon: string;
}

interface Props {
	contacts: Contact[];
}

const { contacts } = Astro.props;
---

<section class="contact" id="contact">
	<div class="contact-container">
		<h2 class="section-heading"><span class="section-num">03.</span> Contact <div class="heading-line"></div></h2>
		<p>Reach out to discuss projects, collaborations, or opportunities.</p>
		<div class="contact-grid">
			{contacts.map((contact) => (
				<a href={contact.href} class="contact-card" target="_blank" rel="noopener noreferrer">
					<span class="icon">{contact.icon}</span>
					<p class="label">{contact.label}</p>
					<p class="value">{contact.value}</p>
				</a>
			))}
		</div>

		<!-- ── Bottom 2-column section ── -->
		<div class="contact-bottom">

			<!-- Left: Contact Form -->
			<div class="contact-form-wrap">
				<h3 class="col-heading">Send a Message</h3>
				<form class="contact-form" name="contact" method="POST" action="#">
					<div class="form-group">
						<label for="cf-name">Name</label>
						<input type="text" id="cf-name" name="name" placeholder="Your name" required />
					</div>
					<div class="form-group">
						<label for="cf-email">Email</label>
						<input type="email" id="cf-email" name="email" placeholder="your@email.com" required />
					</div>
					<div class="form-group">
						<label for="cf-message">Message</label>
						<textarea id="cf-message" name="message" rows="5" placeholder="What's on your mind?" required></textarea>
					</div>
					<button type="submit" class="send-btn">Send Message</button>
				</form>
			</div>

			<!-- Right: System Status card -->
			<div class="status-card">
				<div class="status-header">
					<span class="status-dot"></span>
					<span class="status-title">System Status</span>
				</div>
				<div class="status-rows">
					<div class="status-row">
						<span class="status-key">Location</span>
						<span class="status-val">Prague, Czechia</span>
					</div>
					<div class="status-row">
						<span class="status-key">Objective</span>
						<span class="status-val">
							<span class="live-dot"></span>
							Seeking Embedded Systems Internship
						</span>
					</div>
					<div class="status-row">
						<span class="status-key">Local Time</span>
						<span class="status-val" id="cet-clock">—</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	(function () {
		const el = document.getElementById('cet-clock') as HTMLElement | null;
		if (!el) return;
		function tick() {
			el!.textContent = new Date().toLocaleTimeString('en-GB', {
				timeZone: 'Europe/Prague',
				hour: '2-digit',
				minute: '2-digit',
				second: '2-digit',
			}) + ' CET';
		}
		tick();
		setInterval(tick, 1000);
	})();
</script>

<style>
	.contact {
		padding: 5rem 2rem;
		color: var(--text);
	}

	.contact-container {
		max-width: var(--container);
		margin: 0 auto;
	}

	.contact-container > p {
		color: var(--text-muted);
		margin-bottom: 2.5rem;
		font-size: 1.1rem;
		line-height: 1.7;
	}

	/* ── Cards grid ── */
	.contact-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1.5rem;
	}

	/* ── Card (entire card is the <a>) ── */
	.contact-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 2.5rem 1.5rem;
		background: rgba(15, 15, 15, 0.6);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 16px;
		text-decoration: none;
		color: var(--text);
		text-align: center;
		transition: transform 0.25s cubic-bezier(0.23, 1, 0.32, 1),
		            border-color 0.25s ease,
		            box-shadow 0.25s ease;
	}

	.contact-card:hover {
		transform: translateY(-5px);
		border-color: var(--accent);
		box-shadow: 0 8px 24px rgba(0, 217, 255, 0.15);
	}

	/* ── Icon pill ── */
	.icon {
		font-size: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 64px;
		height: 64px;
		border-radius: 999px;
		background: rgba(0, 217, 255, 0.1);
		color: var(--accent);
		flex-shrink: 0;
	}

	/* ── Label ── */
	.label {
		margin: 0;
		color: var(--accent);
		font-weight: 700;
		font-size: 0.95rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	/* ── Value ── */
	.value {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.95rem;
		word-break: break-all;
	}

	/* ── Bottom 2-col section ── */
	.contact-bottom {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		margin-top: 3rem;
	}

	@media (max-width: 640px) {
		.contact-bottom { grid-template-columns: 1fr; }
	}

	.col-heading {
		font-size: 1rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--accent);
		margin: 0 0 1.25rem 0;
	}

	/* ── Form ── */
	.contact-form-wrap {
		background: rgba(15, 15, 15, 0.6);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 16px;
		padding: 1.75rem;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.form-group label {
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--text-muted);
	}

	.contact-form input,
	.contact-form textarea {
		background: rgba(15, 15, 15, 0.6);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 8px;
		color: var(--text);
		font-size: 0.9rem;
		font-family: inherit;
		padding: 0.65rem 0.9rem;
		outline: none;
		resize: vertical;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.contact-form input::placeholder,
	.contact-form textarea::placeholder {
		color: rgba(255, 255, 255, 0.2);
	}

	.contact-form input:focus,
	.contact-form textarea:focus {
		border-color: var(--accent);
		box-shadow: 0 0 0 3px rgba(0, 217, 255, 0.1);
	}

	.send-btn {
		align-self: flex-start;
		padding: 0.75rem 1.75rem;
		background: var(--accent);
		color: #000;
		border: none;
		border-radius: 10px;
		font-weight: 700;
		font-size: 0.9rem;
		font-family: inherit;
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.send-btn:hover {
		transform: translateY(-3px);
		box-shadow: 0 0 20px rgba(0, 217, 255, 0.45), 0 6px 16px rgba(0, 217, 255, 0.2);
	}

	/* ── Status card ── */
	.status-card {
		background: rgba(15, 15, 15, 0.6);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 16px;
		padding: 1.75rem;
		font-family: 'Fira Code', 'Monaco', 'Courier New', monospace;
	}

	.status-header {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 1.5rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.status-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 8px var(--accent);
	}

	.status-title {
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
	}

	.status-rows {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.status-row {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.status-key {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(255, 255, 255, 0.3);
	}

	.status-val {
		font-size: 0.85rem;
		color: var(--text);
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	/* Pulsing green live dot */
	.live-dot {
		display: inline-block;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #22c55e;
		box-shadow: 0 0 6px #22c55e;
		flex-shrink: 0;
		animation: pulse-green 2s ease-in-out infinite;
	}

	@keyframes pulse-green {
		0%, 100% { opacity: 1; transform: scale(1); }
		50%       { opacity: 0.5; transform: scale(0.75); }
	}
</style>


