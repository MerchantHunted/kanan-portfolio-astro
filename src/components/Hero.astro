---
interface Props {
	name: string;
	title?: string;
	bio?: string;
}

const { bio } = Astro.props;
---

<section id="about" class="hero">
	<div class="hero-content">
		<h1 class="animate-1">Engineering Embedded Systems.</h1>
		<h2 class="animate-2">Firmware &amp; Embedded Systems Engineer</h2>
		{bio && <p class="animate-3">{bio}</p>}
		<div class="cta-buttons animate-4">
			<a href="#projects" class="button primary">View Projects</a>
			<a href="#contact" class="button glass">Contact Me</a>
		</div>
		<div class="doc-buttons animate-5">
			<a href="/CV_Kanan_Abdullayev.pdf" class="button utility" target="_blank" rel="noopener noreferrer">
				<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
				Download CV
			</a>
			<a href="/Letter_of_Recommendation_prof_Hamhalter.pdf" class="button utility" target="_blank" rel="noopener noreferrer">
				<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
				Recommendation Letter
			</a>
		</div>
	</div>
</section>

<style>
	/* ── Background: blueprint grid + accent glow ── */
	.hero {
		position: relative;
		padding: 4rem 2rem 3.5rem;
		text-align: center;
		color: var(--text);
		overflow: hidden;

		/* Blueprint grid */
		background-color: var(--bg);
		background-image:
			linear-gradient(rgba(0, 217, 255, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(0, 217, 255, 0.04) 1px, transparent 1px);
		background-size: 48px 48px;
	}

	/* Radial accent glow centered behind text */
	.hero::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 70% 55% at 50% 45%, rgba(0, 217, 255, 0.08) 0%, transparent 70%);
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		max-width: var(--container);
		margin: 0 auto;
		z-index: 1;
	}

	/* ── Typography ── */
	h1 {
		font-size: clamp(2.5rem, 8vh, 4.2rem);
		margin: 0 0 2.5rem 0;
		color: var(--text);
		font-weight: 900;
		line-height: 1.1;
		letter-spacing: -0.03em;
	}

	h2 {
		font-size: clamp(1rem, 2.5vw, 1.25rem);
		color: var(--accent);
		margin: 0 0 2rem 0;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	p {
		font-size: 1.05rem;
		color: var(--text-muted);
		max-width: 62ch;
		margin: 0 auto 1.5rem;
		line-height: 1.75;
	}

	/* ── Buttons ── */
	.cta-buttons {
		display: flex;
		gap: 1.25rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.button {
		display: inline-block;
		padding: 0.875rem 2rem;
		border-radius: 10px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease, border-color 0.22s ease;
		cursor: pointer;
	}

	/* Primary: solid cyan */
	.button.primary {
		background: var(--accent);
		color: #000;
		border: 1px solid var(--accent);
	}

	.button.primary:hover {
		transform: translateY(-4px);
		box-shadow: 0 0 24px rgba(0, 217, 255, 0.5), 0 8px 20px rgba(0, 217, 255, 0.25);
	}

	/* Glass: semi-transparent outline */
	.button.glass {
		background: rgba(255, 255, 255, 0.05);
		color: var(--text);
		border: 1px solid rgba(255, 255, 255, 0.18);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.button.glass:hover {
		transform: translateY(-4px);
		background: rgba(255, 255, 255, 0.1);
		border-color: var(--accent);
		color: var(--accent);
	}

	/* Doc row */
	.doc-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: nowrap;
		margin-top: 0.85rem;
	}

	@media (max-width: 480px) {
		.doc-buttons { flex-wrap: wrap; }
	}

	/* Utility: dark glass document buttons */
	.button.utility {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(255, 255, 255, 0.03);
		color: var(--text-muted);
		border: 1px solid rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		font-size: 0.85rem;
		padding: 0.6rem 1.25rem;
	}

	.button.utility:hover {
		transform: translateY(-3px);
		background: rgba(0, 217, 255, 0.06);
		border-color: rgba(0, 217, 255, 0.4);
		color: var(--accent);
		box-shadow: 0 4px 16px rgba(0, 217, 255, 0.12);
	}

	/* ── Entrance animations ── */
	@keyframes fadeSlideUp {
		from {
			opacity: 0;
			transform: translateY(28px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-1 { animation: fadeSlideUp 0.65s ease both; animation-delay: 0.05s; }
	.animate-2 { animation: fadeSlideUp 0.65s ease both; animation-delay: 0.2s; }
	.animate-3 { animation: fadeSlideUp 0.65s ease both; animation-delay: 0.35s; }
	.animate-4 { animation: fadeSlideUp 0.65s ease both; animation-delay: 0.5s; }
	.animate-5 { animation: fadeSlideUp 0.65s ease both; animation-delay: 0.65s; }
</style>
